# --- Local configuration & secrets (NEVER commit) ---
# Only commit config.example.yaml; anything else is a real deployment config.
config.yaml
config.yml
config.*.yaml
config.*.yml
!config.example.yaml
.env
.env.*
*.key
*.pem
*credentials*
*secret*

# --- Go build artifacts ---
# Root-level binaries (from `go build ./cmd/...` run at repo root).
/agent
/saas
/datafeeder
*.exe
*.test
*.out
*.prof

# Go test cache / coverage
coverage.txt
coverage.out
profile.cov

# vendor/ is excluded; we use Go modules.
vendor/

# --- Local tool data ---
# Claude Code local settings + graphify knowledge-graph output.
.claude/
graphify-out/

# Agent local SQLite idempotency store (config.agent.yaml db_path; default
# agent.db) + its WAL/SHM sidecars. Per-process runtime state, never committed.
agent.db
*.db-wal
*.db-shm

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Logs & temp ---
*.log
tmp/
.tmp/
