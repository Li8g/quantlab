# Frontend build-time configuration (Vite). Copy to `.env` (or `.env.local`)
# and adjust per deployment, then `npm run build`. Only VITE_* vars are
# exposed to the client bundle.

# G3 — optuna-dashboard deep-link target for the "Analysis ↗" nav item.
# optuna-dashboard has NO authentication, so it must never be bound to a
# public interface. Two supported setups:
#
#   dev (VM, host browser reaching the VM directly):
#     launch:  optuna-dashboard sqlite:///quantlab_phase1.db --host 0.0.0.0 --port 8088
#     build:   VITE_OPTUNA_URL=http://192.168.67.129:8088/
#
#   mainnet (zero-exposure, default): bind localhost only and reach it over an
#   SSH tunnel — `ssh -L 8088:127.0.0.1:8088 <server>` — then open localhost:8088.
#     launch:  optuna-dashboard sqlite:///quantlab_phase1.db --port 8088   # defaults to 127.0.0.1
#     build:   VITE_OPTUNA_URL=http://localhost:8088/   # (also the App.tsx fallback if unset)
VITE_OPTUNA_URL=http://localhost:8088/
